# Base URL of the deployed backend API (used for seller payouts and subscription billing).
# In local dev this can be left unset — Vite proxies /api to http://localhost:4000 (see vite.config.js).
VITE_BACKEND_API_BASE_URL=https://blorbify.onrender.com/api

# Where Paystack redirects the buyer after checkout completes. Must match a route the app
# actually serves — see the "/payment/success" route in src/App.jsx (PaymentSuccess.jsx).
VITE_PAYSTACK_CALLBACK_URL=https://blorbmart-tr1i.onrender.com/payment/success

# Base URL used to build shareable public storefront links (e.g. https://blorbify.vercel.app/your-store).
# Defaults to window.location.origin if unset.
VITE_PUBLIC_STORE_BASE_URL=
