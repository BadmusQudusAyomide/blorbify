# Base URL of the deployed backend API (used for seller payouts and subscription billing).
# In local dev this can be left unset — Vite proxies /api to http://localhost:4000 (see vite.config.js).
VITE_BACKEND_API_BASE_URL=https://blorbify.onrender.com/api

# Where Paystack redirects the buyer after checkout completes. This must be this backend's own
# GET /payment/callback route (see backend/src/app.js) — it verifies the payment server-side,
# applies it, and then redirects on to the frontend's /payment/success page using the
# per-request returnUrl stored in the transaction metadata. Do not point this straight at the
# frontend (bypasses server-side verification) or at an unrelated/external deployment.
VITE_PAYSTACK_CALLBACK_URL=https://blorbify.onrender.com/payment/callback

# Base URL used to build shareable public storefront links (e.g. https://blorbify.vercel.app/your-store).
# Defaults to window.location.origin if unset.
VITE_PUBLIC_STORE_BASE_URL=
